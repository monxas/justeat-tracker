# ── Required ──

# Home Assistant base URL (no trailing slash)
HA_URL=http://homeassistant.local:8123

# Long-lived access token from HA (Profile → Security → Long-Lived Access Tokens).
# Recommended: create a dedicated user "justeat-tracker" with minimum scope.
HA_TOKEN=eyJxxxxxxx...

# ── Optional ──

# Sensor entity ID to push state to. Default: sensor.justeat_tracking
# SENSOR_ID=sensor.justeat_tracking

# Country / region. Default: es. Known presets: es, uk, ie, it, fr, dk, no, ch, at.
# Only ES is verified; others follow the TLD pattern.
# COUNTRY=es

# Override auth host (only needed if your market is not in the preset map).
# Example for UK: AUTH_HOST=auth.just-eat.co.uk
# AUTH_HOST=

# Override API host. Default works for all markets: i18n.api.just-eat.io
# API_HOST=i18n.api.just-eat.io

# Override storefront URL used in Origin/Referer headers. Default derived from
# AUTH_HOST by swapping "auth." → "www.".
# STOREFRONT_URL=https://www.just-eat.es

# OAuth client_id. Default: consumer_web_je (web app client, public, no secret).
# CLIENT_ID=consumer_web_je
